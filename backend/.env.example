# ============================================================
# Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Application ---
APP_NAME="AI Resume Screening System"
APP_VERSION="1.0.0"
DEBUG=true

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/resume_screening
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/resume_screening

# --- JWT Authentication ---
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- File Upload ---
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# --- Email (Gmail SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME="AI Resume Screening"
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_USE_TLS=true

# --- AI Model ---
AI_MODEL_NAME=all-MiniLM-L6-v2
